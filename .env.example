# Copy to .env.local and fill in. Never commit .env.local.

# Groq — LLM that generates sessions (https://console.groq.com)
GROQ_API_KEY=

# Spotify app credentials — used server-side for track search
# (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OPTIONAL — enables the shared "Flow Discoveries" playlist Save.
# Generate once with: node scripts/get-refresh-token.mjs (see README).
# If left empty the app still runs; Save is simply hidden.
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_PLAYLIST_ID=
